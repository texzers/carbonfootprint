# ─── Firebase Configuration ───────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your Apps → Web App

VITE_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789012
VITE_FIREBASE_APP_ID=1:123456789012:web:abcdef1234567890
VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Google APIs ──────────────────────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials
# Restrict Maps key to: Maps JavaScript API, Places API, Distance Matrix API
# Restrict to your domain(s) in API key restrictions

VITE_GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Gemini API (Cloud Functions only — NEVER expose in frontend) ─────────────
# Google AI Studio → API Keys → Create API Key
# This is used in Cloud Functions (server-side) only

GEMINI_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ─── Gemini Proxy URL (points to Cloud Function) ─────────────────────────────
# After deploying Cloud Functions, set this to the geminiStream function URL
# Format: https://REGION-PROJECT_ID.cloudfunctions.net/geminiStream

VITE_GEMINI_PROXY_URL=https://us-central1-your-project-id.cloudfunctions.net/geminiStream

# ─── SendGrid (Cloud Functions only) ─────────────────────────────────────────
# SendGrid → Settings → API Keys → Create API Key (Full Access)

SENDGRID_API_KEY=SG.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# ─── App URL (used in Cloud Functions for CORS and email links) ───────────────

APP_URL=https://your-project-id.web.app

# ─── Notes ───────────────────────────────────────────────────────────────────
# 1. Copy this file to .env.local for local development
# 2. NEVER commit .env.local to source control (it's in .gitignore)
# 3. For Firebase Hosting, set environment variables via:
#    firebase functions:config:set sendgrid.key="SG.xxx" gemini.key="AIza..."
# 4. For Vite variables, they MUST start with VITE_ to be accessible in the browser
# 5. GEMINI_API_KEY must NEVER start with VITE_ — it stays server-side only
